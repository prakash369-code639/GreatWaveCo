//@version=6
indicator("Great Wave v5.5 Indicator", overlay=true, max_labels_count=500)

//=====================================================================
// INPUTS
//=====================================================================
groupDaily  = "Daily Regime"
groupHourly = "Hourly Setup"
groupExec   = "6m Execution"
groupVWAP   = "VWAP Bands"
groupDisp   = "Display"
groupRev    = "Reverse Carry"

emaFastLen = input.int(9,  "EMA Fast", minval=1, group=groupExec)
emaSlowLen = input.int(20, "EMA Slow", minval=1, group=groupExec)

macdFast   = input.int(12, "MACD Fast", group=groupDaily)
macdSlow   = input.int(26, "MACD Slow", group=groupDaily)
macdSignal = input.int(9,  "MACD Signal", group=groupDaily)

showDailyCloud = input.bool(true, "Plot Daily Kumo Lines", group=groupDisp)
showVWAPBands  = input.bool(true, "Plot VWAP Bands", group=groupDisp)
showReverseCarryLabels = input.bool(true, "Show Reverse Carry Labels", group=groupRev)

// Daily Ichimoku settings
convLen  = input.int(9,  "Tenkan", group=groupDaily)
baseLen  = input.int(26, "Kijun",  group=groupDaily)
spanBLen = input.int(52, "Span B", group=groupDaily)

// VWAP band multipliers
band1Mult = input.float(1.0, "VWAP Band 1 Mult", step=0.1, group=groupVWAP)
band2Mult = input.float(2.0, "VWAP Band 2 Mult", step=0.1, group=groupVWAP)

// Reverse carry SMA settings (6m)
revSmaFastLen = input.int(21,  "Reverse Carry SMA Fast", minval=1, group=groupRev)
revSmaSlowLen = input.int(200, "Reverse Carry SMA Slow", minval=2, group=groupRev)

//=====================================================================
// HELPER
//=====================================================================
f_label(_cond, _price, _txt, _style, _bg, _tc) =>
    if _cond
        label.new(bar_index, _price, _txt, style=_style, color=_bg, textcolor=_tc, size=size.small)

//=====================================================================
// 6m INDICATORS
//=====================================================================
emaFast = ta.ema(close, emaFastLen)
emaSlow = ta.ema(close, emaSlowLen)

bullCross6 = ta.crossover(emaFast, emaSlow)
bearCross6 = ta.crossunder(emaFast, emaSlow)

// Reverse carry SMA filter
revSmaFast = ta.sma(close, revSmaFastLen)
revSmaSlow = ta.sma(close, revSmaSlowLen)

revBullCross = ta.crossover(revSmaFast, revSmaSlow)   // kill HBX reverse SELL carry
revBearCross = ta.crossunder(revSmaFast, revSmaSlow)  // kill HSX reverse BUY carry

//=====================================================================
// EVENT GATES
//=====================================================================
newDay  = ta.change(time("D"))  != 0
newHour = ta.change(time("60")) != 0

//=====================================================================
// DAILY DATA
//=====================================================================
dClose = request.security(syminfo.tickerid, "D", close)
dHigh  = request.security(syminfo.tickerid, "D", high)
dLow   = request.security(syminfo.tickerid, "D", low)

dEmaFast = request.security(syminfo.tickerid, "D", ta.ema(close, emaFastLen))
dEmaSlow = request.security(syminfo.tickerid, "D", ta.ema(close, emaSlowLen))

dMacdLine = request.security(syminfo.tickerid, "D", ta.ema(close, macdFast) - ta.ema(close, macdSlow))

dBullCross = request.security(syminfo.tickerid, "D", ta.crossover(ta.ema(close, emaFastLen), ta.ema(close, emaSlowLen)))
dBearCross = request.security(syminfo.tickerid, "D", ta.crossunder(ta.ema(close, emaFastLen), ta.ema(close, emaSlowLen)))

// Daily Ichimoku
dTenkan = request.security(syminfo.tickerid, "D", (ta.highest(high, convLen) + ta.lowest(low, convLen)) / 2.0)
dKijun  = request.security(syminfo.tickerid, "D", (ta.highest(high, baseLen) + ta.lowest(low, baseLen)) / 2.0)
dSpanA  = (dTenkan + dKijun) / 2.0
dSpanB  = request.security(syminfo.tickerid, "D", (ta.highest(high, spanBLen) + ta.lowest(low, spanBLen)) / 2.0)

dCloudUpper = math.max(dSpanA, dSpanB)
dCloudLower = math.min(dSpanA, dSpanB)
dCloudMid   = (dCloudUpper + dCloudLower) / 2.0

strongBuyDaily  = dClose > dCloudUpper and dLow > dCloudUpper
strongSellDaily = dClose < dCloudLower and dHigh < dCloudLower

contBuyDaily =
     dEmaFast > dEmaSlow and
     dMacdLine > 0 and
     dClose > dCloudMid and
     dSpanA > dSpanB and
     dClose > dKijun

contSellDaily =
     dEmaFast < dEmaSlow and
     dMacdLine < 0 and
     dClose < dCloudMid and
     dSpanA < dSpanB and
     dClose < dKijun

//=====================================================================
// DAILY REGIME STATE
//=====================================================================
var bool dailyInBuy  = false
var bool dailyInSell = false

var bool dailyBuyCancelWatch  = false
var bool dailySellCancelWatch = false

dailyStrongBuyEvent  = false
dailyContBuyEvent    = false
dailyStrongSellEvent = false
dailyContSellEvent   = false
dailyBuyCancelEvent  = false
dailySellCancelEvent = false

dailyStrongBuyEvent  := false
dailyContBuyEvent    := false
dailyStrongSellEvent := false
dailyContSellEvent   := false
dailyBuyCancelEvent  := false
dailySellCancelEvent := false

if newDay
    if not dailyInBuy and not dailyInSell
        if strongBuyDaily
            dailyInBuy := true
            dailyInSell := false
            dailyBuyCancelWatch := false
            dailySellCancelWatch := false
            dailyStrongBuyEvent := true
        else if contBuyDaily
            dailyInBuy := true
            dailyInSell := false
            dailyBuyCancelWatch := false
            dailySellCancelWatch := false
            dailyContBuyEvent := true
        else if strongSellDaily
            dailyInSell := true
            dailyInBuy := false
            dailyBuyCancelWatch := false
            dailySellCancelWatch := false
            dailyStrongSellEvent := true
        else if contSellDaily
            dailyInSell := true
            dailyInBuy := false
            dailyBuyCancelWatch := false
            dailySellCancelWatch := false
            dailyContSellEvent := true
    else if dailyInBuy
        if strongSellDaily
            dailyInBuy := false
            dailyInSell := true
            dailyBuyCancelWatch := false
            dailySellCancelWatch := false
            dailyStrongSellEvent := true
        else if contSellDaily
            dailyInBuy := false
            dailyInSell := true
            dailyBuyCancelWatch := false
            dailySellCancelWatch := false
            dailyContSellEvent := true
    else if dailyInSell
        if strongBuyDaily
            dailyInSell := false
            dailyInBuy := true
            dailyBuyCancelWatch := false
            dailySellCancelWatch := false
            dailyStrongBuyEvent := true
        else if contBuyDaily
            dailyInSell := false
            dailyInBuy := true
            dailyBuyCancelWatch := false
            dailySellCancelWatch := false
            dailyContBuyEvent := true

if newDay
    if dailyInBuy and dBearCross
        dailyBuyCancelWatch := true
    if dailyInBuy and dailyBuyCancelWatch and dBullCross
        dailyBuyCancelWatch := false
    if dailyInBuy and dailyBuyCancelWatch and dMacdLine < 0
        dailyInBuy := false
        dailyBuyCancelWatch := false
        dailyBuyCancelEvent := true

    if dailyInSell and dBullCross
        dailySellCancelWatch := true
    if dailyInSell and dailySellCancelWatch and dBearCross
        dailySellCancelWatch := false
    if dailyInSell and dailySellCancelWatch and dMacdLine > 0
        dailyInSell := false
        dailySellCancelWatch := false
        dailySellCancelEvent := true

//=====================================================================
// HOURLY DATA
//=====================================================================
hClose = request.security(syminfo.tickerid, "60", close)

hEmaFast = request.security(syminfo.tickerid, "60", ta.ema(close, emaFastLen))
hEmaSlow = request.security(syminfo.tickerid, "60", ta.ema(close, emaSlowLen))

hBullCross = request.security(syminfo.tickerid, "60", ta.crossover(ta.ema(close, emaFastLen), ta.ema(close, emaSlowLen)))
hBearCross = request.security(syminfo.tickerid, "60", ta.crossunder(ta.ema(close, emaFastLen), ta.ema(close, emaSlowLen)))

hEmaSlowPrev = request.security(syminfo.tickerid, "60", ta.ema(close, emaSlowLen)[1])
hSlopeUp   = hEmaSlow > hEmaSlowPrev
hSlopeDown = hEmaSlow < hEmaSlowPrev

hVWAP = request.security(syminfo.tickerid, "60", ta.vwap(hlc3))

hourlyBuyValid  = hBullCross and hClose > hVWAP and hSlopeUp
hourlySellValid = hBearCross and hClose < hVWAP and hSlopeDown

//=====================================================================
// HOURLY ARM STATE
//=====================================================================
var bool hourlyArmedBuy  = false
var bool hourlyArmedSell = false

hourlyBuyArmEvent         = false
hourlySellArmEvent        = false
hourlyBuyInvalidateEvent  = false
hourlySellInvalidateEvent = false

hourlyBuyArmEvent         := false
hourlySellArmEvent        := false
hourlyBuyInvalidateEvent  := false
hourlySellInvalidateEvent := false

if newHour
    if dailyInBuy and hourlyBuyValid
        hourlyArmedBuy := true
        hourlyArmedSell := false
        hourlyBuyArmEvent := true

    if dailyInSell and hourlySellValid
        hourlyArmedSell := true
        hourlyArmedBuy := false
        hourlySellArmEvent := true

    if hourlyArmedBuy and hBearCross
        hourlyArmedBuy := false
        hourlyBuyInvalidateEvent := true

    if hourlyArmedSell and hBullCross
        hourlyArmedSell := false
        hourlySellInvalidateEvent := true

//=====================================================================
// SESSION VWAP + STDEV BANDS
//=====================================================================
newSession = ta.change(time("D")) != 0

tp = hlc3
var float cumPV  = na
var float cumV   = na
var float cumTP2 = na

cumPV  := newSession ? tp * volume : nz(cumPV[1]) + tp * volume
cumV   := newSession ? volume      : nz(cumV[1])  + volume
cumTP2 := newSession ? tp * tp * volume : nz(cumTP2[1]) + tp * tp * volume

vwap = cumPV / cumV
variance = math.max(cumTP2 / cumV - vwap * vwap, 0)
stdev = math.sqrt(variance)

upperBand1 = vwap + stdev * band1Mult
lowerBand1 = vwap - stdev * band1Mult
upperBand2 = vwap + stdev * band2Mult
lowerBand2 = vwap - stdev * band2Mult

//=====================================================================
// NORMAL PULLBACK MEMORY
//=====================================================================
var bool pullbackSeenBuy  = false
var bool pullbackSeenSell = false

buyPullback  = dailyInBuy  and low < lowerBand1 and close > lowerBand1
sellPullback = dailyInSell and high > upperBand1 and close < upperBand1

if buyPullback
    pullbackSeenBuy := true
if sellPullback
    pullbackSeenSell := true

if not dailyInBuy
    pullbackSeenBuy := false
if not dailyInSell
    pullbackSeenSell := false

//=====================================================================
// REVERSE ENGINES (SEPARATED)
//=====================================================================
// BUY side:
//   1) normal reverse SELL while hourly BUY armed
//   2) invalidation reverse SELL after HB X
//
// SELL side:
//   3) normal reverse BUY while hourly SELL armed
//   4) invalidation reverse BUY after HS X
//=====================================================================

// Invalidation carry flags
var bool buyReverseCarry  = false   // after HB X -> reverse SELL invalidation engine
var bool sellReverseCarry = false   // after HS X -> reverse BUY invalidation engine

buyReverseCarryStartEvent  = false
sellReverseCarryStartEvent = false
buyReverseCarryEndEvent    = false
sellReverseCarryEndEvent   = false

buyReverseCarryStartEvent  := false
sellReverseCarryStartEvent := false
buyReverseCarryEndEvent    := false
sellReverseCarryEndEvent   := false

// Start carry
if hourlyBuyInvalidateEvent and dailyInBuy
    buyReverseCarry := true
    buyReverseCarryStartEvent := true

if hourlySellInvalidateEvent and dailyInSell
    sellReverseCarry := true
    sellReverseCarryStartEvent := true

// Carry expiry by SMA regime
if buyReverseCarry and revBullCross
    buyReverseCarry := false
    buyReverseCarryEndEvent := true

if sellReverseCarry and revBearCross
    sellReverseCarry := false
    sellReverseCarryEndEvent := true

// Kill carry if daily regime dies
if not dailyInBuy
    buyReverseCarry := false

if not dailyInSell
    sellReverseCarry := false

//=====================================================================
// NORMAL TRADE ENTRY LOGIC
//=====================================================================
tradeBuy  = dailyInBuy  and hourlyArmedBuy  and pullbackSeenBuy  and bullCross6
tradeSell = dailyInSell and hourlyArmedSell and pullbackSeenSell and bearCross6

if tradeBuy
    pullbackSeenBuy := false

if tradeSell
    pullbackSeenSell := false

//=====================================================================
// NORMAL REVERSE WATCHES
//=====================================================================
// These exist ONLY while hourly arm is alive
//=====================================================================
var bool reverseSellWatch_normal = false   // from hourly BUY armed zone only
var bool reverseBuyWatch_normal  = false   // from hourly SELL armed zone only

// reset if hourly regime dies
if not hourlyArmedBuy
    reverseSellWatch_normal := false

if not hourlyArmedSell
    reverseBuyWatch_normal := false

// normal reverse observation
if dailyInBuy and hourlyArmedBuy and high >= upperBand2
    reverseSellWatch_normal := true

if dailyInSell and hourlyArmedSell and low <= lowerBand2
    reverseBuyWatch_normal := true

//=====================================================================
// INVALIDATION REVERSE WATCHES
//=====================================================================
// These exist ONLY in HB X / HS X carry zone
//=====================================================================
var bool reverseSellWatch_invalid = false   // after HB X only
var bool reverseBuyWatch_invalid  = false   // after HS X only

// clear invalid watches if carry dies
if not buyReverseCarry
    reverseSellWatch_invalid := false

if not sellReverseCarry
    reverseBuyWatch_invalid := false

// invalidation reverse observation
if buyReverseCarry and high >= upperBand2
    reverseSellWatch_invalid := true

if sellReverseCarry and low <= lowerBand2
    reverseBuyWatch_invalid := true

//=====================================================================
// REVERSE TRIGGERS
//=====================================================================
// Normal engines
reverseSell_normal = dailyInBuy and hourlyArmedBuy and reverseSellWatch_normal and bearCross6
reverseBuy_normal  = dailyInSell and hourlyArmedSell and reverseBuyWatch_normal and bullCross6

// Invalidation engines
reverseSell_invalid = dailyInBuy and buyReverseCarry and reverseSellWatch_invalid and bearCross6
reverseBuy_invalid  = dailyInSell and sellReverseCarry and reverseBuyWatch_invalid and bullCross6

reverseSell = reverseSell_normal or reverseSell_invalid
reverseBuy  = reverseBuy_normal  or reverseBuy_invalid

// Post-fire cleanup
if reverseSell_normal
    reverseSellWatch_normal := false

if reverseBuy_normal
    reverseBuyWatch_normal := false

if reverseSell_invalid
    reverseSellWatch_invalid := false
    buyReverseCarry := false

if reverseBuy_invalid
    reverseBuyWatch_invalid := false
    sellReverseCarry := false

//=====================================================================
// EXIT LOGIC
//=====================================================================
failureExitLong  = dailyInBuy  and (hourlyArmedBuy or buyReverseCarry)  and bearCross6 and close < vwap
failureExitShort = dailyInSell and (hourlyArmedSell or sellReverseCarry) and bullCross6 and close > vwap

hourlyExitLong  = dailyInBuy  and newHour and hBearCross and not buyReverseCarry
hourlyExitShort = dailyInSell and newHour and hBullCross and not sellReverseCarry

dailyExitLong   = dailyBuyCancelEvent
dailyExitShort  = dailySellCancelEvent

if hourlyExitLong or dailyExitLong
    hourlyArmedBuy := false
    buyReverseCarry := false
    reverseSellWatch_normal := false
    reverseSellWatch_invalid := false

if hourlyExitShort or dailyExitShort
    hourlyArmedSell := false
    sellReverseCarry := false
    reverseBuyWatch_normal := false
    reverseBuyWatch_invalid := false

//=====================================================================
// LABELS
//=====================================================================
f_label(dailyStrongBuyEvent,  high, "D BUY+",  label.style_label_down, color.new(color.green, 0), color.white)
f_label(dailyContBuyEvent,    high, "D BUY~",  label.style_label_down, color.new(color.green, 35), color.white)
f_label(dailyStrongSellEvent, low,  "D SELL+", label.style_label_up,   color.new(color.red, 0), color.white)
f_label(dailyContSellEvent,   low,  "D SELL~", label.style_label_up,   color.new(color.red, 35), color.white)

f_label(dailyBuyCancelEvent or dailySellCancelEvent, close, "D CANCEL", label.style_label_left, color.new(color.orange, 0), color.white)

f_label(hourlyBuyArmEvent,         low,  "HB",   label.style_label_up,   color.new(color.lime, 0), color.black)
f_label(hourlySellArmEvent,        high, "HS",   label.style_label_down, color.new(color.maroon, 0), color.white)
f_label(hourlyBuyInvalidateEvent,  high, "HB X", label.style_label_down, color.new(color.orange, 0), color.white)
f_label(hourlySellInvalidateEvent, low,  "HS X", label.style_label_up,   color.new(color.orange, 0), color.white)

f_label(tradeBuy,  low,  "TRADE BUY",  label.style_label_up,   color.new(color.green, 0), color.white)
f_label(tradeSell, high, "TRADE SELL", label.style_label_down, color.new(color.red, 0), color.white)

f_label(reverseSell, high, "REVERSE SELL", label.style_label_down, color.new(color.orange, 0), color.white)
f_label(reverseBuy,  low,  "REVERSE BUY",  label.style_label_up,   color.new(color.aqua, 0), color.black)

//f_label(failureExitLong,  high, "FAIL EXIT", label.style_label_down, color.new(color.yellow, 0), color.black)
//f_label(failureExitShort, low,  "FAIL EXIT", label.style_label_up,   color.new(color.yellow, 0), color.black)

f_label(hourlyExitLong or dailyExitLong,  high, "EXIT", label.style_label_down, color.new(color.yellow, 30), color.black)
f_label(hourlyExitShort or dailyExitShort, low, "EXIT", label.style_label_up,   color.new(color.yellow, 30), color.black)

f_label(showReverseCarryLabels and buyReverseCarryStartEvent, high, "REV SELL ARM", label.style_label_down, color.new(color.orange, 55), color.white)
f_label(showReverseCarryLabels and sellReverseCarryStartEvent, low,  "REV BUY ARM",  label.style_label_up,   color.new(color.aqua, 55), color.black)

f_label(showReverseCarryLabels and buyReverseCarryEndEvent, high, "REV SELL OFF", label.style_label_down, color.new(color.gray, 30), color.white)
f_label(showReverseCarryLabels and sellReverseCarryEndEvent, low,  "REV BUY OFF",  label.style_label_up,   color.new(color.gray, 30), color.white)

//=====================================================================
// PLOTS
//=====================================================================
plot(showDailyCloud ? dCloudUpper : na, title="Daily Cloud Upper", color=color.orange, linewidth=2)
plot(showDailyCloud ? dCloudLower : na, title="Daily Cloud Lower", color=color.blue, linewidth=2)
plot(showDailyCloud ? dCloudMid   : na, title="Daily Cloud Mid",   color=color.gray, linewidth=1)
plot(showDailyCloud ? dKijun      : na, title="Daily Kijun",       color=color.teal, linewidth=1)

plot(emaFast, title="EMA 9", color=color.new(color.green, 0))
plot(emaSlow, title="EMA 20", color=color.new(color.red, 0))

plot(showVWAPBands ? vwap       : na, title="VWAP",         color=color.purple, linewidth=2)
plot(showVWAPBands ? upperBand1 : na, title="Upper Band 1", color=color.fuchsia)
plot(showVWAPBands ? lowerBand1 : na, title="Lower Band 1", color=color.fuchsia)
plot(showVWAPBands ? upperBand2 : na, title="Upper Band 2", color=color.orange)
plot(showVWAPBands ? lowerBand2 : na, title="Lower Band 2", color=color.orange)

plot(revSmaFast, title="Reverse SMA 21", color=color.new(color.yellow, 0))
plot(revSmaSlow, title="Reverse SMA 200", color=color.new(color.gray, 0))
